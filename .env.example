# Firebase (from Firebase Console > Project Settings > Web App)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# LiveKit (from LiveKit Cloud dashboard)
# Public WS URL — safe in frontend
VITE_LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# Set in Firebase Functions env, NOT in frontend:
#   firebase functions:config:set livekit.api_key=... livekit.api_secret=...
