# Firebase (from Firebase Console > Project Settings > Web App)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# LiveKit (from LiveKit Cloud dashboard)
# Public WS URL — safe in frontend
VITE_LIVEKIT_WS_URL=wss://your-project.livekit.cloud

# Cloudflare Worker URL that mints LiveKit tokens (deployed from worker/)
VITE_TOKEN_ENDPOINT=https://podcast-platform-token.<your-subdomain>.workers.dev

# These are NOT in frontend — set as Worker secrets:
#   cd worker && wrangler secret put LIVEKIT_API_KEY
#                wrangler secret put LIVEKIT_API_SECRET
#                wrangler secret put LIVEKIT_WS_URL
#                wrangler secret put FIREBASE_PROJECT_ID
