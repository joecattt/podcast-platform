rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isHost() {
      return request.auth != null
          && request.auth.token.email_verified == true
          && request.auth.token.email == 'whitehat@joecattt.com';
    }

    // Singleton show settings doc.
    match /shows/{showId} {
      allow read: if request.auth != null;
      allow write: if isHost();
    }

    match /rooms/{roomId} {
      allow read: if request.auth != null;
      // Only the host can create rooms.
      allow create: if isHost() && request.resource.data.hostUid == request.auth.uid;
      // Only the host can update / delete.
      allow update: if isHost() && resource.data.hostUid == request.auth.uid;
      allow delete: if isHost() && resource.data.hostUid == request.auth.uid;

      // Per-room participants — anyone signed in can add themselves.
      match /participants/{uid} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == uid;
      }
    }

    // Episode docs — created/updated by the pipeline (admin SDK bypasses rules)
    // but readable to anyone authenticated for the dashboard.
    match /episodes/{episodeId} {
      allow read: if request.auth != null;
      allow write: if isHost();
    }
  }
}
